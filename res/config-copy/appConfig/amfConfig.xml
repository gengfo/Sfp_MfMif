<amf-system xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<application>
		<application-name>ARP</application-name>
		<host-name>localhost</host-name>
		<port-number>7222</port-number>
	</application>

	<!-- The jndi-properties element is not used now, if use it in the futrue. 
		If used, then need set global value "USE_JNDI_ENV_PARM" in config.xml as 
		"true" -->
	<jndi-properties>
		<java.naming.factory.initial>
			oracle.j2ee.rmi.RMIInitialContextFactory
		</java.naming.factory.initial>
		<java.naming.provider.url>
			ormi://localhost:23791/Async_MF
		</java.naming.provider.url>
		<java.naming.security.principal>
			oc4jadmin
		</java.naming.security.principal>
		<java.naming.security.credentials>
			welcome
		</java.naming.security.credentials>
	</jndi-properties>

	<!-- receiver destination's connection-facatory must be a non-XA connection 
		factory If no recovery queue, just set <dest-recovery-queue-name> with empty 
		value -->

	<receiver>
		<!-- receiver msg-destinations *****************start -->
		<msg-destinations>

			<msg-destination>
				<dest-name>RS.IPS.TEST.MSG.QUEUE</dest-name>
				<connection-factory>
					MessageFrameworkPoolCF
				</connection-factory>
				<number-destination-instances>
					1
				</number-destination-instances>
				<queue>
					<dest-exception-queue-name>
						RS.IPS.TEST.MSG.QUEUEEXCEPTION
					</dest-exception-queue-name>
					<dest-recovery-queue-name>
						RS.IPS.TEST.MSG.QUEUEEXCEPTION
					</dest-recovery-queue-name>
					<number-recovery-instances>
						1
					</number-recovery-instances>
				</queue>
			</msg-destination>

			<!-- receiver msg-destinations ***************** end -->
		</msg-destinations>

		<!-- receiver msg-brokers ***************** start -->
		<msg-brokers>

			<dest-broker>
				<msg-dest-name>RS.IPS.TEST.MSG.QUEUE</msg-dest-name>
				<default-dest-broker-class-name>
					com.oocl.frm.mif.mf.receiver.broker.MFMessageBrokerAdapter
				</default-dest-broker-class-name>
				<msg-type-broker>
					<type-broker-class-name>
						com.oocl.frm.mif.mf.receiver.broker.MFMessageBrokerAdapter
					</type-broker-class-name>
					<messageType>
						<root-element>MifRootElement</root-element>
						<name-space>MifNameSpace</name-space>
					</messageType>
				</msg-type-broker>
			</dest-broker>

		</msg-brokers>
		<!-- receiver msg-brokers ***************** end -->
	</receiver>

	<sender>
		<!-- msg-destinations ******************* start -->
		<msg-destinations>

			<msg-destination>
				<dest-name>RS.IPS.TEST.MSG.QUEUE</dest-name>
				<isQueue>true</isQueue>
				<connection-factory>
					MessageFrameworkPoolCF
				</connection-factory>
			</msg-destination>
			
		</msg-destinations>
		<!-- msg-destinations ******************* end -->
	</sender>

