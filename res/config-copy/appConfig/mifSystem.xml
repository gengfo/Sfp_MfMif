<?xml version="1.0" encoding="UTF-8"?>
<sys:sysConfig xmlns:sys="http://www.oocl.com/frm/mif/sys"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
       http://www.oocl.com/frm/mif/sys mifSystem.xsd">
	<sys:instanceName>IPS_INS</sys:instanceName>
	<sys:apps>
		<sys:app>
			<sys:id>ARP</sys:id>
			<sys:name>ARP</sys:name>
		</sys:app>
		<sys:app>
			<sys:id>TMS-2</sys:id>
			<sys:name>Transportation System II</sys:name>
		</sys:app>
	</sys:apps>

	<!-- IPS handled logs in app level-->
	<sys:info>
		<sys:statusLog>
			<sys:sender>
				<sys:excludes>
					<sys:exclude>
						<sys:message>.*</sys:message>
						<sys:app>.*</sys:app>
					</sys:exclude>
				</sys:excludes>
			</sys:sender>
			<sys:receiver>
				<sys:excludes>
					<sys:exclude>
						<sys:message>.*</sys:message>
						<sys:app>.*</sys:app>
					</sys:exclude>
				</sys:excludes>
			</sys:receiver>
		</sys:statusLog>
	</sys:info>

	<sys:dataSource>
		<sys:jndiLocation>ipsDev</sys:jndiLocation>
	</sys:dataSource>

	

</sys:sysConfig>
