<?xml version="1.0" encoding="UTF-8"?>
<sender:senderConfig xmlns:sender="http://www.oocl.com/frm/mif/sender"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://www.oocl.com/frm/mif/mifSender.xsd">

	<!-- sender:messages ***************** start -->
	<sender:messages>

		<sender:message type="TestMsgType">
			<sender:version value="ver1.0">
				<sender:apps>
					<sender:app id="ARP">
						<sender:converter
							class="com.oocl.frm.mif.sender.converter.impl.EmptySenderConverter">
						</sender:converter>
					</sender:app>
				</sender:apps>
			</sender:version>
		</sender:message>

	</sender:messages>

	<sender:destinations>

		<sender:destination id="TestMsgDestination">
			<sender:messages>
				<sender:message type="TestMsgType">
					<sender:version value="ver1.0">
						<sender:decorators>
							<sender:decorator refId="jaxbXmlBeansJmsDecrator" />
						</sender:decorators>
						<sender:transporter
							class="com.oocl.frm.mif.mf.sender.transporter.MFJMSSenderTransporterWithDefault">
							<sender:params>
								<sender:param key="destinationName" value="RS.IPS.TEST.MSG.QUEUE">
								</sender:param>
							</sender:params>
						</sender:transporter>
					</sender:version>
				</sender:message>
			</sender:messages>
		</sender:destination>

	</sender:destinations>

	<!-- sender:destinations ***************** end -->

	<!-- sender:decorator ***************** start -->

	<sender:decorator id="jaxbXmlBeansJmsDecrator"
		class="mypack.msg.sender.decrator.DirectedJAXBXMLBeansToMFJmsSenderDecorator">
	</sender:decorator>

	<!-- sender:decorator ***************** end -->

</sender:senderConfig>
