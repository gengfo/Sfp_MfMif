<?xml version="1.0" encoding="UTF-8"?>
<receiver:receiverConfig xmlns:receiver="http://www.oocl.com/frm/mif/receiver"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="
       http://www.oocl.com/frm/mif/receiver mifReceiver.xsd">
	<!-- messages ***************** start -->

	<receiver:messages>

		<receiver:message type="TestMsgType">
			<receiver:version value="ver1.0">
				<receiver:app receiverId="ARP">
					<receiver:decorators>
						<receiver:decorator
							class="com.oocl.frm.mif.mf.common.decorator.jaxb.MFToJAXBXmlBeansDecorator">
							<receiver:params>
								<receiver:param key="xmlDocInterfaceName"
									value="mypack.msg.schema.TestMsgEventDocument" />
							</receiver:params>
						</receiver:decorator>
					</receiver:decorators>
					<receiver:converter
						class="mypack.msg.receiver.convertor.TestMsgConvertor">
					</receiver:converter>
					<receiver:processor
						class="mypack.msg.receiver.processor.TestMsgProcessor">
					</receiver:processor>
				</receiver:app>
			</receiver:version>
		</receiver:message>

	</receiver:messages>


	<!-- messages ***************** end -->

	<!-- process ***************** start -->
	<receiver:processes>

		<receiver:process id="RS.IPS.TEST.MSG.QUEUE">
			<receiver:messageType>TestMsgType</receiver:messageType>
			<receiver:messageVersion>ver1.0</receiver:messageVersion>
			<receiver:receiverId>ARP</receiver:receiverId>
		</receiver:process>

	</receiver:processes>

	<!-- process ***************** end -->

</receiver:receiverConfig>
