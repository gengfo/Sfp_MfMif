<?xml version="1.0" encoding="UTF-8"?>

<Component> 
  <subcomponent name="art" class="com.oocl.csc.frm.integration.configurator.impl.FWBaseSimpleSubConfigComponent"> 
    <!-- DATA_LOCATION's value should be "local" or "remote", default value is "remote" -->  
    <var name="DATA_LOCATION" value="remote"/>  
    <!-- BUFFER_SIZE's default value is 20, and maximum value is 100 -->  
    <!--gengfo: todo set to 1 on dev, set to 20 on production-->  
    <var name="BUFFER_SIZE" value="20"/>  
    <!-- set time schedule interval in milliseconds. If delay limit reached, the records in buffer will be reported, 
	     no matter if buffer is full, its default value is 90000 -->  
    <var name="DELAY_LIMIT" value="60000"/>  
    <!-- THREAD_NUMBER's default value is 10, and maximum value is 50 -->  
    <var name="THREAD_NUMBER" value="30"/>  
    <!--gengfo: todo -->  
    <!--
    <var name="ART_DATACENTRE_WS_ENDPOINT" value="http://artdcpp/artdc/ARTClientReportReceiver.asmx"/> 
    -->  
    <!--
    <var name="ART_DATACENTRE_WS_ENDPOINT" value="http://testwebdev22/artdcuat/ARTClientReportReceiver.asmx"/> 
    -->  
    <var name="ART_DATACENTRE_WS_ENDPOINT" value="http://testwebdev22/artdcuat/ARTClientReportReceiver.asmx"/>  
    <!--Should same as the the hostname or IP of the DATACENTRE_WS_ENDPOINT -->  
    <!--gengfo: todo -->  
    <var name="ART_WORK_DIRECTORY" value="C:/ips_oc4j_101350/j2ee/home/log/ivo_app_log/art/"/>  
    <!-- ART_TRACE_STATUS' value should be "ON" or "OFF", default value is "ON". -->  
    <!--gengfo -->  
    <var name="ART_TRACE_STATUS" value="ON"/>  
    <!-- ERROR_HANDLING_STATUS' value should be "ON" or "OFF", default value is "ON". -->  
    <!--gengfo: todo set to ON on production,on means art handle error, off then will throw exception-->  
    <var name="ERROR_HANDLING_STATUS" value="ON"/>  
    <var name="DATECENTRE_DETECTION_PERIOD" value="60000"/>  
    <!-- unit: milliseconds --> 
  </subcomponent>  
  <subcomponent name="artMessageLogger" class="com.oocl.csc.frm.integration.logger.impl.FWLoggerSubConfigComponent"> 
    <var name="LOG_ENABLED" value="true"/>  
    <var name="FORCED_FATAL" value="true"/>  
    <var name="LOG_ERROR" value="true"/>  
    <var name="LOG_FATAL" value="true"/>  
    <var name="LOG_INFO" value="true"/>  
    <var name="LOG_WARNING" value="true"/>  
    <var name="LOG_DEBUG" value="true"/>  
    <var name="LOGGER_SPECIFIC_PROPERTIES_FILE" value=""/> 
  </subcomponent> 
</Component>
<!--
#############################################################################################
#   Properties file "art" for ART framework (Java Web Service)                              #
#   "art" subcomponent in artConfig.xml														#
#   Auther: Joseph.Li(ISDC-OCHL/SHA)                                                        #
#   LMD: May 21, 2004             															#	
#   Modified by David Ding: 3/6/2007                                                       	#
#                                                                                           #
#   Defines the parameters used in ART framework                                            #
#                                                                                           #
#   Note:                                                                                   #
#                                                                                           #
#   1.  The DATA_LOCATION is used to indicate the way of processing the ARTContexts when    #
#       logging. It can be set as remote or local, remote style sends the ARTContexts to ART#
#       Data Centre via Web Services while local style writes them to local files in text   #
#       format. 																			#
#																							#	
#   2.  The BUFFER_SIZE is used to set buffer size for ART Contexts, all the contexts in the#										
#       buffer will be sent to data centre or wrote to a local file together				#                                        								
#                                                                                           #
#   3.  The THREAD_NUMBER is used to put a threshold on the spawn threads and prevent       #
#       the abuse of system resource. ART framework will send the ARTContexts to DataCentre #
#       or write to local log files in spawned threads.                                     #
#                                                                                           #
#   4.  The ART_DATACENTRE_WS_ENDPOINT is used to indicate the Web Service of ART Data      #
#       Centre.														                        #
#                                                                                           #
#   5.  The ART_WORK_DIRECTORY is used to indicate the directory where all the recovery     #
#       files will be saved.												                #
#                                                                                           #
#   6.  The ART_TRACE_STATUS is a global switch used to filter the ARTContexts with high    #
#       flexiblity. If the ART_TRACE_STATUS is set with "ON", all the ARTContexts will be   #
#       logged; if it is "OFF", none will be logged.							            #
#  																							#
#   7.  During development or testing, ERROR_HANDLING_STATUS is set with "OFF", runtime 	#
#       exception will be thrown whenever an error is encountered in the Agent. In 			#
#       production environment, it is set with "ON", no runtime exceptions will be thrown.	#
#       Instead, errors will be handled and logged to error file.							#
#                                                                                           #
#   8.  The DATECENTRE_DETECTION_PERIOD is used remind the ART Framework to resend the      #
#       ARTContexts in the recovery log when last submission is failure. The value is set   #
#       in milliseconds.                                                                    #
#                                                                                           #
#############################################################################################
-->
