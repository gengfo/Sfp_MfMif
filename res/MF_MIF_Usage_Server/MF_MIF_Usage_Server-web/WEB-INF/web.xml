<?xml version="1.0"?>
<!DOCTYPE web-app PUBLIC "-//Sun Microsystems, Inc.//DTD Web Application 2.2//EN" "http://java.sun.com/j2ee/dtds/web-app_2_2.dtd">
<web-app>
	<display-name>TIR Application</display-name>

	<servlet>
		<servlet-name>FWConfigLoaderServlet</servlet-name>
		<servlet-class>
			com.oocl.csc.frm.integration.configuration.loader.servlet.FWConfigLoaderServlet
		</servlet-class>

		<init-param>
			<param-name>APP_NAME</param-name>
			<param-value>MF_MIF_Usage</param-value>
		</init-param>

		<init-param>
			<param-name>APP_SERVER_INSTANCE_NAME</param-name>
			<param-value>MF_MIF_Usage_Server</param-value>
		</init-param>

		<init-param>
			<param-name>APP_CONFIG_FILE_PATH</param-name>
			<param-value>config.xml</param-value>
		</init-param>

		<load-on-startup>1</load-on-startup>
	</servlet>
	
	<servlet>
		<servlet-name>MIFStartUPServlet</servlet-name>
		<servlet-class>
			com.oocl.frm.mif.startup.MIFStartupServlet
		</servlet-class>

		<init-param>
			<param-name>STARTUP_TYPE</param-name>
			<param-value>both</param-value>
		</init-param>
		<load-on-startup>2</load-on-startup>
	</servlet>

	<servlet>
		<servlet-name>FWMessageLoaderServlet</servlet-name>
		<servlet-class>
			com.oocl.frm.messaging.receiver.loader.FWMessageLoaderServlet
		</servlet-class>
		<!-- loaded after FWConfigLoaderServlet -->
		<load-on-startup>3</load-on-startup>
	</servlet>
	
	<servlet>
		<servlet-name>HelloWorldServlet</servlet-name>
		<servlet-class>
			mypack.servlet.HelloWorldServlet
		</servlet-class>
		<load-on-startup>4</load-on-startup>
	</servlet>

	<servlet-mapping>
		<servlet-name>HelloWorldServlet</servlet-name>
		<url-pattern>/Hello</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>SendMsgServlet</servlet-name>
		<servlet-class>
			mypack.servlet.SendMsgServlet
		</servlet-class>
		<load-on-startup>2</load-on-startup>
	</servlet>

	<servlet-mapping>
		<servlet-name>SendMsgServlet</servlet-name>
		<url-pattern>/SendMsg</url-pattern>
	</servlet-mapping>
	
	<servlet>
		<servlet-name>ReceiveMsgServlet</servlet-name>
		<servlet-class>
			mypack.servlet.ReceiveMsgServlet
		</servlet-class>
		<load-on-startup>2</load-on-startup>
	</servlet>

	<servlet-mapping>
		<servlet-name>ReceiveMsgServlet</servlet-name>
		<url-pattern>/ReceiveMsg</url-pattern>
	</servlet-mapping>


</web-app>